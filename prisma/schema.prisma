// Prisma schema – SQLite for now, written for future Postgres compatibility.
// Use portable types: String (uuid), DateTime; avoid DB-specific features in schema.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum AccountType {
  BANK
  CREDIT
  SERVICE
  OTHER
}

enum RuleType {
  FIXED_DAY
  RANGE
}

enum DueStatus {
  PENDING
  PAID
}

model Account {
  id        String   @id @default(uuid())
  name      String
  type      AccountType
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  bills     Bill[]
}

model Rule {
  id        String   @id @default(uuid())
  type      RuleType
  config    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  bills     Bill[]
}

model Bill {
  id        String   @id @default(uuid())
  accountId String
  ruleId    String
  amount    Float?
  account   Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  rule      Rule          @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  dueInstances DueInstance[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([accountId, ruleId])
}

model DueInstance {
  id               String    @id @default(uuid())
  billId           String
  dueDate          DateTime
  estimatedAmount  Float?
  confirmedAmount  Float?
  status           DueStatus @default(PENDING)
  paidAt           DateTime?
  createdAt        DateTime  @default(now())
  bill             Bill      @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@unique([billId, dueDate])
  @@index([billId])
  @@index([dueDate])
  @@index([status])
}
