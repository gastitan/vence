{
  "name": "dueflow",
  "version": "1.0.0",
  "description": "Vence is a mobile app that reminds and *predicts* financial due dates (cards, services, loans, installments) using **rules instead of manually entered dates**.",
  "homepage": "https://github.com/gastitan/vence#readme",
  "bugs": {
    "url": "https://github.com/gastitan/vence/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gastitan/vence.git"
  },
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "dist/start.js",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @dueflow/engine && tsc -p tsconfig.build.json",
    "prestart": "npm run build",
    "test": "npm run test -w @dueflow/engine && node scripts/test-with-db.mjs",
    "test:vitest": "vitest run",
    "start": "node dist/start.js",
    "dev": "tsx watch src/start.ts",
    "stop": "pkill -f 'dist/start.js' || true"
  },
  "dependencies": {
    "@dueflow/engine": "file:packages/engine",
    "@prisma/adapter-better-sqlite3": "^7.4.1",
    "better-sqlite3": "^12.6.2",
    "express": "^5.2.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@prisma/client": "^7.4.1",
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.3",
    "dotenv": "^17.3.1",
    "prisma": "^7.4.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
